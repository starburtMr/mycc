# Obsidian 绑定配置（示例）

# 1=启用 Obsidian 集成，0=禁用（默认）
export OBSIDIAN_ENABLED=0

# Obsidian CLI 命令名（一般是 obsidian）
export OBSIDIAN_CLI_BIN="obsidian"

# 可选：指定 vault 名称（用于 obsidian vault=<name> ...）
export OBSIDIAN_VAULT_NAME=""

# 可选：为知识沉淀指定默认文件夹（vault 内相对路径）
export OBSIDIAN_DEFAULT_FOLDER="CC-AGENT-SPACE/10-Tasks"

# 笔记路由根目录（用于按 type 自动分发）
export OBSIDIAN_ROOT_FOLDER="CC-AGENT-SPACE"
export OBSIDIAN_FOLDER_INBOX="CC-AGENT-SPACE/00-Inbox"
export OBSIDIAN_FOLDER_TASKS="CC-AGENT-SPACE/10-Tasks"
export OBSIDIAN_FOLDER_ADRS="CC-AGENT-SPACE/20-ADRs"
export OBSIDIAN_FOLDER_SOP="CC-AGENT-SPACE/30-SOP"
export OBSIDIAN_FOLDER_PROFILE="CC-AGENT-SPACE/40-Profile"
export OBSIDIAN_FOLDER_ARCHIVE="CC-AGENT-SPACE/99-Archive"

# 默认笔记属性
export OBSIDIAN_DEFAULT_TYPE="task"
export OBSIDIAN_DEFAULT_STATUS="active"
export OBSIDIAN_DEFAULT_TAGS="cc,task"
export OBSIDIAN_NOTE_SOURCE="codex"
export OBSIDIAN_NOTE_OWNER="cc"

# 1=强制 Frontmatter 与中文检查
export OBSIDIAN_ENFORCE_FRONTMATTER=1
export OBSIDIAN_REQUIRE_CHINESE=1

# Obsidian 笔记仓库路径（用于自动 git push）
export OBSIDIAN_REPO_PATH="/mnt/data/obsidian"

# 1=每次写笔记后自动 push，0=关闭
export OBSIDIAN_GIT_AUTO_PUSH=1

# 推送分支
export OBSIDIAN_GIT_BRANCH="master"
