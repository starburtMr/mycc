# Agent-Reach 受限接入配置示例

# 1=启用适配层；0=禁用（默认）
export AGENT_REACH_ENABLED=0

# 运行目录（建议使用项目内隔离目录）
export AGENT_REACH_HOME="/mnt/data/mycc/.runtime/agent-reach"

# 上游仓库与分支
export AGENT_REACH_REPO="https://github.com/Panniantong/Agent-Reach.git"
export AGENT_REACH_REF="main"

# 强制受限：不允许脚本自动改代理配置
export AGENT_REACH_NO_AGENT_CONFIG=1

# 诊断默认输出
export AGENT_REACH_DIAGNOSE_OUT_DEFAULT="/mnt/data/mycc/3-Thinking/sessions/agent-reach-diagnose.json"
